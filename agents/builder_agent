from __future__ import annotations

import json
from schemas.state import CircuitState
from utils.llm_utils import call_llm

def _build_system_prompt(state: CircuitState) -> str:
    system_prompt = (
    "【角色與職責】\n"
    "你是一位專精於合成生物學的「生物邏輯架構師（Bio-Logic Architect）」。\n"
    "你的任務是將使用者的自然語言需求，轉化為具備「生物物理學感知」的基因電路邏輯網路。\n"
    "請記住：你的設計最終將由 Cello CAD 系統編譯為實體 DNA。你【必須】考量生物資源極限與訊號延遲，並輸出 Cello 能夠理解且不會錯誤優化（Optimize away）的代碼格式。\n\n"
    
    "【Skill Library 閱讀與應用指南】\n"
    "系統會提供一份 JSON 格式的 Skill Library 作為你的標準元件庫。設計時請遵守以下原則：\n"
    "- `estimated_repressor_cost`：單一方案的總抑制子消耗量【絕對不可超過 10 個】。\n"
    "- 防禦競爭危害 (Race Condition)：若並行訊號邏輯深度不同，請主動安插 Buffer (如雙重 NOT 閘) 來對齊訊號。\n"
    "- 【極度重要：Cello 編譯器陷阱】：Cello 是一個純組合邏輯化簡器。若你設計了動態網路 (如 Pulse Generator 的 I1-FFL)，Cello 會將 `A AND NOT(A)` 化簡為 `0`。因此，涉及時間動態的 Motif，你【必須】使用特殊標籤保護，或者使用「結構化 Verilog (Structural Verilog, 即明確呼叫 NOR/NOT 閘)」而非「行為化 Verilog (assign Y = A & B)」。\n\n"

    f"【最高設計法則：基於生物學妥協 (Trade-offs) 的多樣性】\n"
    f"為了達成用戶目標：【{state.user_intent}】，你必須提出 3 種基於不同生物學權衡的候選方案：\n"
    "1. 方案 A (Minimal Cost)：追求最低的 repressor_cost，容許輕微漏電。\n"
    "2. 方案 B (Minimal Delay)：追求最淺的 logic_depth，降低轉錄級聯延遲。\n"
    "3. 方案 C (Robust & Dynamic)：容許高資源消耗，主動安插抗噪或動態控制 Motif。\n\n"
    
    "【輸出格式規範】"
    "請嚴格以 JSON 格式輸出，不要包含任何 Markdown 標記，直接輸出合法 JSON 字串。"
    "{\n"
    '  "proposal_a": {\n'
    '    "strategy_description": "描述你的設計策略與妥協考量",\n'
    '    "total_logic_depth": 2,\n'
    '    "total_repressor_cost": 3,\n'
    '    "logic_blueprint": "Z = PULSE_GENERATOR(X, Y_repressor)", // 使用高階的 Motif 或邏輯表達式\n'
    '    "translator_directives": ["PRESERVE_LOGIC: PULSE_GENERATOR", "USE_STRUCTURAL_INSTANTIATION"] // 給 Translator 的明確施工指令\n'
    '  },\n'
    '  "proposal_b": { ... },\n'
    '  "proposal_c": { ... }\n'
    "}\n"
)
    # 附加 Skill Library (以字串形式注入前述建構好的 JSON)
    # 載入「設計邏輯」Skill Library 標準元件庫
    try:
        with open("邏輯設計skill.json", "r", encoding="utf-8") as f:
            skill_library = f.read()
        system_prompt += f"\n\n【邏輯設計 (Skill Library 標準元件庫)】\n{skill_library}"
    except Exception:
        # 如果檔案讀取失敗，則回退至 state 提供的內容
        if hasattr(state, 'skill_library_context') and state.skill_library_context:
            system_prompt += f"\n\n【本次載入的 Skill Library 標準元件庫】\n{state.skill_library_context}"
        elif state.rag_context: 
            system_prompt += f"\n\n【本次檢索到的參考知識 (Skill Library / RAG)】\n{state.rag_context}"

    # 若有 Critic 提供的退回修改建議，加入背景中
    if state.latest_critic_feedback:
        system_prompt += (
            "\n\n【來自 Critic 的退回修改/HITL 介入建議】\n"
            "前一次的邏輯設計在轉譯、Cello 實體編譯或人類審查時，發現存在缺陷或有新的追加條件。\n"
            f"請務必嚴格遵循以下反饋重新設計邏輯：\n{state.latest_critic_feedback}\n"
        )
        
    return system_prompt
