    def extract_and_package_skill(
        self, 
        dialogue_history: str, 
        benchmark_reports: str, 
        metadata: Dict[str, Any]
    ) -> Optional[Dict[str, Any]]:
        """
        Extracts high-level biological design skills from the provided logs and packages them with the experiment metadata.

        Args:
            dialogue_history (str): The conversation transcript between Builder and Critic.
            benchmark_reports (str): The performance metrics and evaluations from the Benchmark system.
            metadata (Dict[str, Any]): A dictionary containing environmental variables (e.g., experiment_id, host_organism, user_intent).

        Returns:
            Optional[Dict[str, Any]]: A merged dictionary containing the metadata and the extracted skills.
                                      Returns None if no valuable insight was extracted or an error occurred.
        """
        prompt = (
            f"=== 實驗背景 (Metadata) ===\n"
            f"{json.dumps(metadata, ensure_ascii=False, indent=2)}\n\n"
            f"=== 對話紀錄 (Builder & Critic Dialogue) ===\n"
            f"{dialogue_history}\n\n"
            f"=== 評分報告 (Benchmark Reports) ===\n"
            f"{benchmark_reports}\n\n"
            f"請根據上述資訊，提煉出高階生物學設計經驗。"
        )

        try:
            experiment_id = metadata.get('experiment_id', 'UNKNOWN')
            logger.info(f"Extracting skills for experiment: {experiment_id}")
            
            # 1. Call LLM with structured output schema
            llm_response: LLMSkillOutput = self._call_llm_structured(prompt)
            
            # 2. Check if valuable insights were found
            if not llm_response.has_valuable_insight:
                logger.info(f"No valuable insight found for experiment {experiment_id} (Skipping).")
                return None
            
            logger.info(f"Valuable skills successfully extracted for experiment {experiment_id}.")
            
            # 3. Merge extracted skills with the incoming metadata
            packaged_skill = metadata.copy()
            if llm_response.extracted_skills:
                # model_dump() is available in Pydantic V2. (Use dict() for V1)
                packaged_skill["skills"] = llm_response.extracted_skills.model_dump(exclude_none=True)
            else:
                packaged_skill["skills"] = {}
            
            # 4. Save to Staging Directory (Physical Isolation)
            import os
            pending_dir = "skills_pending"
            os.makedirs(pending_dir, exist_ok=True)
            
            # Sanitize experiment_id for filename
            safe_exp_id = str(experiment_id).replace(":", "-").replace(" ", "_")
            file_path = os.path.join(pending_dir, f"skill_{safe_exp_id}.json")
            
            with open(file_path, "w", encoding="utf-8") as f:
                json.dump(packaged_skill, f, ensure_ascii=False, indent=2)
                
            logger.info(f"Successfully saved extracted skill to {file_path}")
            
            return packaged_skill

        except NotImplementedError as e:
            logger.warning(str(e))
            # Return a mock output for demonstration if NotImplementedError is raised
            return None
        except Exception as e:
            logger.error(f"Failed to extract and package skills: {e}")
            return None
