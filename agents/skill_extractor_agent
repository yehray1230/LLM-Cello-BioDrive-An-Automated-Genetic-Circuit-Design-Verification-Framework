import json
import logging
from typing import Any, Dict, Optional

from pydantic import BaseModel, Field

logger = logging.getLogger(__name__)


class ModuleSkill(BaseModel):
    """
    Represents the extracted skill for a specific evaluation module.
    """
    has_skill: bool = Field(
        ..., 
        description="Whether a valuable skill was extracted for this module."
    )
    rule_summary: Optional[str] = Field(
        default=None, 
        description="The summary of the extracted rule (e.g., '避免在大腸桿菌中重複使用 pTac 啟動子，以防同源重組')."
    )


class ExtractedSkills(BaseModel):
    """
    Contains the skills extracted across the three evaluation dimensions.
    """
    module_1_plausibility: ModuleSkill = Field(
        ..., 
        description="Skills related to structural plausibility and biological feasibility."
    )
    module_2_functional: ModuleSkill = Field(
        ..., 
        description="Skills related to logic compliance and functional fold-change."
    )
    module_3_kinetic: ModuleSkill = Field(
        ..., 
        description="Skills related to kinetic robustness and metabolic burden."
    )


class LLMSkillOutput(BaseModel):
    """
    The structured JSON output expected from the LLM after analyzing the design history.
    """
    has_valuable_insight: bool = Field(
        ..., 
        description="True if valuable design rules can be extracted. False if the iteration was just syntax errors or meaningless attempts."
    )
    extracted_skills: Optional[ExtractedSkills] = Field(
        default=None, 
        description="The extracted skills categorized by evaluation module. Should be provided if has_valuable_insight is True."
    )


