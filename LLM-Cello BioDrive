# =========================
# 後端邏輯：核心轉譯函式
# =========================
def _model_requires_api_key(model_name: str) -> bool:
    # LiteLLM: ollama/* 走本地，不需要 API key；其他供應商通常需要
    return not str(model_name or "").startswith("ollama/")

def _validate_verilog_ast(code: str) -> tuple[bool, str]:
    """輕量級正則語意校驗，確保具備 Cello Verilog 所需基本要素。"""
    if "module " not in code or "endmodule" not in code:
        return False, "缺乏 `module` 或 `endmodule` 宣告。"
    if "input " not in code:
        return False, "缺乏 `input` 腳位宣告。"
    if "output " not in code:
        return False, "缺乏 `output` 腳位宣告。"
    # 簡易邏輯運算字眼檢查
    has_logic = any(kw in code for kw in ["and(", "or(", "not(", "nor(", "nand(", "assign "])
    if not has_logic:
        return False, "缺乏具體邏輯運算 (如 and, or, not) 或 assign 語句。"
    return True, ""


def generate_verilog(user_intent: str, api_key: str | None, model_name: str, api_base: str | None = None) -> str:
    """
    使用指定的 OpenAI API Key，根據使用者的自然語言需求，
    產生對應的 Cello Verilog 程式碼。

    回傳：
    - 成功：純 Verilog 程式碼字串。
    - 失敗：以「錯誤：」開頭的錯誤訊息字串（方便前端識別）。
    """
    if _model_requires_api_key(model_name) and (not api_key or not api_key.strip()):
        return "錯誤：尚未提供模型供應商 API Key。"

    if not user_intent or not user_intent.strip():
        return "錯誤：自然語言需求不可為空白。"

    
    system_prompt = """You are an expert biological circuit compiler for the Cello CAD software. Your ONLY job is to translate structured specifications into standard structural/dataflow Verilog code.

STRICT RULES:

1. Output ONLY raw, valid Verilog code.
2. NO Markdown formatting (Do NOT use ```verilog or ```).
3. Convert "Biological_Constraints" and "Selected_Parts" into Verilog comments using `// Cello pragma:` at the top.
4. 【Logic Translation Rules】:
   - For simple combinational logic, use gates (and, or, not, etc.) or assign statements.
   - For sequential biological logic (e.g., biological memory, toggle switches), use Behavioral Verilog (e.g., `reg`, `always` blocks, edge triggers) to represent state changes.
   - For temporal dynamics (e.g., delayed expression, lysis countdown), you may use Verilog delay syntax (e.g., `#10`) to model the biological time delay.
5. 【Multi-Cellular Consortia】: If the specification involves multiple cell types communicating with each other (e.g., Sender and Receiver), you MUST output multiple separate `module` blocks, and potentially a top-level module to wire the intercellular chemical signals together.
"""

    messages = [
        {"role": "system", "content": system_prompt},
        {
            "role": "user",
            "content": (
                "請根據以下自然語言描述，設計對應的 Cello Verilog 基因電路：\n"
                f"{user_intent}"
            ),
        },
    ]

    max_retries = 3

    for attempt in range(max_retries):
        try:
            response = litellm.completion(
                model=model_name,
                messages=messages,
                temperature=0.2,  # 降低隨機性，讓輸出更穩定
                api_key=api_key.strip() if api_key and api_key.strip() else None,
                api_base=api_base.strip() if api_base and api_base.strip() else None,
            )

            raw_output = response.choices[0].message["content"]

            # 正規表達式區塊萃取：只捕捉 // Cello pragma 註解以及 module ... endmodule 內容
            match = re.search(r"(?s)(?:^\s*//.*?\n)*module\s+\w+\s*\(.*?\);.*?endmodule", raw_output, re.MULTILINE)
            if not match:
                err_msg = "無法從輸出中萃取完整的 Verilog 區塊 (module ... endmodule)。"
                if attempt < max_retries - 1:
                    messages.append({"role": "assistant", "content": raw_output})
                    messages.append({"role": "user", "content": f"【格式校驗失敗】{err_msg} 請務必只產出純 Verilog 程式碼，移除其餘非語法宣告的對白與 Markdown。"})
                    continue
                return f"錯誤：{err_msg}\n模型輸出原文：\n{raw_output}"

            extracted_code = match.group(0).strip()

            # 輕量級語法與語意校驗
            is_valid, val_err = _validate_verilog_ast(extracted_code)
            if not is_valid:
                if attempt < max_retries - 1:
                    messages.append({"role": "assistant", "content": extracted_code})
                    messages.append({"role": "user", "content": f"【語意校驗失敗】{val_err} 請修正後重新產出。"})
                    continue
                return f"錯誤：多次重試後語法校驗依然失敗：{val_err}"

            # 若通過校驗，立即返回
            return extracted_code

        except litellm.exceptions.AuthenticationError:
            return "錯誤：模型供應商 API 驗證失敗，請確認 API Key 是否正確與有效。"
        except litellm.exceptions.RateLimitError:
            return "錯誤：已達到模型供應商使用上限或額度不足，請稍後再試或檢查帳戶狀態。"
        except litellm.exceptions.BadRequestError as e:
            return f"錯誤：請求參數不正確：{str(e)}"
        except litellm.exceptions.APIError as e:
            return f"錯誤：呼叫模型供應商 API 時發生問題：{str(e)}"
        except Exception as e:
            return f"錯誤：系統發生未預期錯誤：{str(e)}"

    return "錯誤：產生 Verilog 失敗，超過最大重試次數。"


# =========================
# 多機辯論區塊（Reflexion）：三輪迭代 設計→評估→修改
# =========================
def _call_llm(api_key: str | None, model_name: str, system_prompt: str, user_content: str, api_base: str | None = None) -> str:
    """
    共用的 LLM 呼叫與錯誤處理，供 call_builder / call_critic / call_summarizer 使用。
    成功回傳助理回覆文字；失敗回傳以「錯誤：」開頭的字串。
    """
    try:
        response = litellm.completion(
            model=model_name,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_content},
            ],
            temperature=0.3,
            api_key=api_key.strip() if api_key and api_key.strip() else None,
            api_base=api_base.strip() if api_base and api_base.strip() else None,
        )
        return response.choices[0].message["content"].strip()
    except litellm.exceptions.AuthenticationError:
        return "錯誤：模型供應商 API 驗證失敗，請確認 API Key 是否正確與有效。"
    except litellm.exceptions.RateLimitError:
        return "錯誤：已達到模型供應商使用上限或額度不足，請稍後再試或檢查帳戶狀態。"
    except litellm.exceptions.BadRequestError as e:
        return f"錯誤：請求參數不正確：{str(e)}"
    except litellm.exceptions.APIError as e:
        return f"錯誤：呼叫模型供應商 API 時發生問題：{str(e)}"
    except Exception as e:
        return f"錯誤：系統發生未預期錯誤：{str(e)}"


def call_builder(
    user_intent: str,
    previous_feedback: str,
    api_key: str | None,
    model_name: str,
    *,
    rag_context: str = "",
    round1_debate_transcript: str | None = None,
    api_base: str | None = None,
    force_zero_shot: bool = False,
) -> str:
    """
    專家一：合成生物學系統工程師（Reflexion 版）。
    若無 previous_feedback 則提出 V1；若有則在「絕對不違反用戶最終目標」前提下提出修正版。
    round1_debate_transcript：僅在第一輪且無 previous_feedback 時使用，將此前完整辯論紀錄一併納入語境。
    """
    system_prompt = (
        "【角色與職責】\n"
        "你是一位極具創造力且精通系統生物學的首席架構師（Builder）。"
        f"你的唯一任務是竭盡所能，利用可用的生物元件達成用戶的最終目標：【{user_intent}】\n\n"
        "【最高設計法則：意圖驅動與學理辯護】\n"
        "1. 忠於意圖的極致創新：不要被傳統數位電路的死板邏輯侷限。為了達成用戶目標，你可以大膽且合理地引入【負回饋/正回饋迴路】、【時序延遲機制】、【雙穩態記憶開關】或【細胞裂解/死亡機制】等高階生物學拓樸結構。\n"
        "2. 勇敢辯護 (Defensive Design)：面對 Critic（安全審查員）的批評時，你【不需要】無條件妥協。若 Critic 警告了代謝負擔、元件毒性或邏輯衝突，但你認為這些特徵是達成用戶目標的「必要犧牲」或「核心機制」，請以專業的分子生物學原理進行強而有力的反駁與辯護，並堅持你的設計。\n"
        "3. 元件的最佳化組合：請靈活運用提供的 RAG 元件庫，若發現無法用單一細胞實現複雜邏輯，可主動提議將電路拆分為多個互助的細胞群體（Consortia），並說明胞間通訊訊號。\n\n"
        "【回應格式規範】\n"
        "若未收到 Critic 意見，請直接給出包含感測器、邏輯閘、輸出與動態調控原理的完整架構 (V1)。\n"
        "若收到 Critic 意見，請先明確表態【接受修改】或【學理反駁】，接著給出迭代後的設計與原理解釋。"
    )
    if force_zero_shot:
        system_prompt += (
            f"【優雅降級模式】目前系統 RAG 無法提供完整的外部資料。你必須動用自身學習過的基礎合成生物學知識來完成草圖。"
            f"請以以下基礎元件作為主要參考：\n{rag_context}\n"
        )
    else:
        system_prompt += f"【硬性約束】你只能使用以下 Cello 元件庫進行設計：\n{rag_context}\n絕對禁止使用清單外或捏造的元件。"
    if previous_feedback:
        user_content = f"【批評者意見，請據此修正設計】\n{previous_feedback}"
    elif round1_debate_transcript:
        user_content = (
            "【此前完整辯論紀錄（請承接脈絡，不可忽略；並須完全符合下方「用戶最終目標」）】\n"
            f"{round1_debate_transcript}\n\n"
            "請綜合以上紀錄與用戶最終目標，提出本輪第一版（V1）基因電路設計。"
        )
    else:
        user_content = "請根據上述用戶最終目標，提出第一版（V1）基因電路設計。"
    return _call_llm(api_key, model_name, system_prompt, user_content, api_base=api_base)


def call_critic(
    current_design: str,
    user_intent: str,
    api_key: str | None,
    model_name: str,
    *,
    rag_context: str = "",
    debate_transcript: str | None = None,
    api_base: str | None = None,
    force_zero_shot: bool = False,
) -> str:
    """
    專家二：嚴苛的生物安全與可行性審查員。
    只專注於：邏輯矛盾、生物學現實問題（代謝負擔、毒性）、生物安全風險。提出精確、致命的批評。
    debate_transcript：若有，一併提供此前辯論紀錄供語境對齊（例如追加條件後的再辯論）。
    """
    system_prompt = (
        "【角色與職責】\n"
        "你是一位高階合成生物學審查員（Critic）。你的任務是確保 Builder 提出的基因電路設計既符合「使用者的原始意圖」，又具備生物學上的合理性。\n\n"
        f"【使用者的設計意圖（Target Intent）】：{user_intent}\n\n"
        "【多維度審查法則】\n"
        "你在審查時必須進行以下三個層次的評估，並於回覆最前方清楚標示對應的標籤：\n\n"
        "1. 🛑 [INTENT_INVALID 意圖不合理]：檢視使用者的需求本身是否違反熱力學定律、分子生物學常理，或超出合成生物學的技術極限（例如：要求大腸桿菌憑空合成黃金）。若是，請指出需求的不合理處，並建議 Builder 如何引導使用者修改目標。\n"
        "2. ⚠️ [MISALIGNMENT 意圖偏離]：Builder 的設計雖然安全，但卻因為「過度保守」或「邏輯錯誤」而沒有達成使用者的原始意圖（例如：使用者要求振盪器，Builder 卻只給出單向開關；或使用者要求細胞裂解，Builder 卻移除了毒性元件）。請要求 Builder 重新對齊意圖。\n"
        "3. 🛑 [FATAL 致命阻斷]：設計中出現「未預期」的邏輯短路或嚴重生物毒性。⚠️注意：若使用者的意圖本就包含『細胞死亡』、『裂解』或『動態負回饋』，對應的元件毒性或抑制作用即為【合法設計】，絕不可標記為 FATAL，但需提醒控制其 Leakage（洩漏表現）。\n\n"
        "【審查焦點】\n"
        "請綜合以上三點進行無情但精確的點評，專注於物理與生物矛盾，直接給出修正指令。"
    )
    if force_zero_shot:
        system_prompt += (
            f"【審查基準】現在處於優雅降級模式，Builder 會動用自身知識與基礎元件（如：\n{rag_context}\n）。"
            "只要元件存在於真實合成生物學中且具體合理，請勿視為捏造而批評，著重於邏輯與生物毒性即可。"
        )
    else:
        system_prompt += f"【審查基準】請嚴格對照以下元件清單：\n{rag_context}\n若 Builder 捏造了清單外的元件，請給予嚴厲批評並要求修正。"
    if debate_transcript:
        user_content = (
            "【此前完整辯論紀錄（供你對齊語境與使用者意圖）】\n"
            f"{debate_transcript}\n\n"
            "【當前待審查的設計】\n"
            f"{current_design}"
        )
    else:
        user_content = current_design
    return _call_llm(api_key, model_name, system_prompt, user_content, api_base=api_base)


def call_summarizer(final_design: str, api_key: str | None, model_name: str, api_base: str | None = None) -> str:
    """
    專家三：首席架構師。
    將第三輪的最終設計濃縮成 Verilog 轉譯器需要的純邏輯自然語言（例如：「當有 A 且沒有 B 時，輸出 C。」）。
    """
    system_prompt = (
        "【角色與職責】\n"
        "你是一位首席系統架構師（Summarizer）。你的任務是將最終達成共識的基因電路設計，精準轉譯為高度結構化的規格書 (Extended Payload)。\n\n"
        "【任務規範】\n"
        "請嚴格依序輸出以下四個區塊，絕不可加入任何廢話：\n\n"
        "1. System_Architecture: (描述網路的拓樸結構。除了基礎布林邏輯外，若設計包含『時序延遲 (Delay)』、『記憶狀態 (Memory/Toggle)』、『負回饋 (Feedback)』或『細胞裂解/死亡』，請務必在此精確標明其動態行為與觸發條件。)\n"
        "2. Consortia_Configuration: (若設計涉及多細胞協同，請說明有哪些不同的細胞株 (Modules) 以及它們之間用於溝通的化學分子；若為單一細胞則填寫 N/A。)\n"
        "3. Biological_Constraints: (條列出設計中提到的所有生化限制，例如毒性控管、拷貝數、或特定代謝負擔的妥協。)\n"
        "4. Selected_Parts: (條列出選用的啟動子、感測器、邏輯閘與輸出元件名稱。)"
    )
    return _call_llm(api_key, model_name, system_prompt, final_design, api_base=api_base)


def format_sessions_for_display(sessions: list[list[dict]]) -> str:
    """將多段三輪辯論整理成給使用者閱讀的完整文字。"""
    parts: list[str] = []
    for si, session in enumerate(sessions, start=1):
        parts.append(f"════════ 在線迭代對抗紀錄 {si} ════════")
        for round_num, turn in enumerate(session, start=1):
            parts.append(f"\n── 迭代輪次 {round_num} ──")
            parts.append("\n【合成生物學系統工程師】\n")
            parts.append(turn.get("builder", ""))
            parts.append("\n\n【嚴苛的生物安全與可行性審查員】\n")
            parts.append(turn.get("critic", ""))
        parts.append("\n")
    return "\n".join(parts).strip()


def format_sessions_for_llm(sessions: list[list[dict]]) -> str:
    """與 display 相同結構即可，供後續輪次餵給 LLM。"""
    return format_sessions_for_display(sessions)


def _compact_rag_context(
    rag_results: list[str] | str,
    *,
    max_items: int = 8,
    max_chars: int = 2400,
) -> str:
    """
    將 RAG 檢索結果壓縮成較短的上下文，避免 Prompt 過長。

    策略：
    - 若是 list：優先保留看起來屬於 sensors / gates / output_devices 的描述
    - 去除重複與空白
    - 限制最多條目數與總字元數
    """
    if isinstance(rag_results, str):
        text = rag_results.strip()
        return text[:max_chars] if len(text) > max_chars else text

    raw_items = [x.strip() for x in rag_results if isinstance(x, str) and x.strip()]
    if not raw_items:
        return ""

    # 依描述字串常見關鍵字做輕量分類（不依賴固定 schema）
    keys = (
        "感測器",
        "sensor",
        "輸入",
        "input",
        "邏輯閘",
        "gate",
        "NOR",
        "NOT",
        "output device",
        "output_device",
        "output_devices",
        "輸出元件",
        "輸出",
    )
    filtered: list[str] = [x for x in raw_items if any(k.lower() in x.lower() for k in keys)]
    if not filtered:
        filtered = raw_items

    # 去重但保持順序
    seen: set[str] = set()
    uniq: list[str] = []
    for x in filtered:
        if x not in seen:
            seen.add(x)
            uniq.append(x)

    # 條目數限制
    uniq = uniq[:max_items]

    # 總長度限制（逐條累加，避免截斷到一半）
    out_lines: list[str] = []
    total = 0
    for item in uniq:
        line = f"- {item}"
        if out_lines:
            projected = total + 1 + len(line)
        else:
            projected = total + len(line)
        if projected > max_chars:
            break
        out_lines.append(line)
        total = projected

    return "\n".join(out_lines).strip()


def get_compressed_rag_context(query: str, api_key: str) -> str:
    """
    取得並壓縮 RAG 元件語境。
    成功：回傳壓縮後字串；失敗：回傳以「錯誤：」開頭的訊息。
    """
    if not api_key or not api_key.strip():
        return "錯誤：尚未提供 API Key。"
    if not query or not query.strip():
        return "錯誤：查詢內容不可為空白。"
    try:
        # Backward-compat shim (OpenAI embeddings only)
        rag_results = search_parts(query, embedding_model="text-embedding-3-small", api_key=api_key)
        if not rag_results:
            return "錯誤：RAG 檢索失敗：未取得任何元件結果。"
        rag_context = _compact_rag_context(rag_results)
        if not rag_context.strip():
            return "錯誤：RAG 檢索失敗：檢索結果為空白。"
        return rag_context
    except Exception as e:
        return f"錯誤：RAG 檢索失敗：{str(e)}"


def get_compressed_rag_context_v2(
    query: str,
    *,
    embedding_model: str,
    embedding_api_key: str | None = None,
    embedding_api_base: str | None = None,
) -> str:
    """
    取得並壓縮 RAG 元件語境（支援本地 embeddings，例如 Ollama）。
    成功：回傳壓縮後字串；失敗：回傳以「錯誤：」開頭的訊息。
    """
    if not query or not query.strip():
        return "錯誤：查詢內容不可為空白。"
    if not embedding_model or not str(embedding_model).strip():
        return "錯誤：尚未指定 Embedding Model。"
    try:
        rag_results = search_parts(
            query,
            embedding_model=embedding_model,
            api_key=embedding_api_key,
            api_base=embedding_api_base,
        )
        if not rag_results:
            return "錯誤：RAG 檢索失敗：未取得任何元件結果。"
        rag_context = _compact_rag_context(rag_results)
        if not rag_context.strip():
            return "錯誤：RAG 檢索失敗：檢索結果為空白。"
        return rag_context
    except Exception as e:
        return f"錯誤：RAG 檢索失敗：{str(e)}"


def run_three_round_reflexion(
    api_key: str | None,
    model_name: str,
    user_intent: str,
    *,
    carry_transcript: str | None = None,
    rag_context: str = "",
    on_round_complete=None,
    api_base: str | None = None,
    force_zero_shot: bool = False,
) -> tuple[bool, list[dict], str | None, str | None]:
    """
    執行三輪 Builder↔Critic。
    carry_transcript：若提供（例如使用者追加條件後），第一輪 Builder 與每一輪 Critic 都會帶入完整此前紀錄。
    on_round_complete：可選，每輪結束時呼叫 callback(round_num, builder_text, critic_text)。
    回傳：(success, 本段三輪的 [{builder, critic}, ...], 第三輪 Builder 產出即最終設計, 錯誤訊息或 None)
    """
    previous_feedback = ""
    session_rounds: list[dict] = []
    final_design: str | None = None
    # 單次預先檢索：在開始三輪辯論前，把最相關的真實元件庫注入上下文
    #（此版本要求呼叫端先取得 rag_context，以便 UI 可展示透明度）
    if not rag_context.strip():
        return False, session_rounds, None, "錯誤：尚未提供 RAG Context。"
    if rag_context.startswith("錯誤："):
        return False, session_rounds, None, rag_context

    for round_num in range(1, 4):
        r1_ctx = carry_transcript if round_num == 1 else None
        current_design = call_builder(
            user_intent,
            previous_feedback,
            api_key,
            model_name,
            rag_context=rag_context,
            round1_debate_transcript=r1_ctx,
            api_base=api_base,
            force_zero_shot=force_zero_shot,
        )
        if current_design.startswith("錯誤："):
            return False, session_rounds, None, current_design

        critic_fb = call_critic(
            current_design=current_design,
            user_intent=user_intent,
            api_key=api_key,
            model_name=model_name,
            rag_context=rag_context,
            debate_transcript=carry_transcript,
            api_base=api_base,
            force_zero_shot=force_zero_shot,
        )
        if critic_fb.startswith("錯誤："):
            return False, session_rounds, None, critic_fb

        session_rounds.append({"builder": current_design, "critic": critic_fb})
        previous_feedback = critic_fb
        final_design = current_design
        if on_round_complete:
            on_round_complete(round_num, current_design, critic_fb)

    return True, session_rounds, final_design, None


