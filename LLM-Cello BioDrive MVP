            "追加條件說明",
            height=100,
            placeholder="例：須避免高拷貝載體；或須符合某實驗室生物安全等級…",
            key=f"debate_extra_condition_{st.session_state['debate_extra_widget_id']}",
        )
        append_go = st.button("(3) 提交追加條件並重新辯論", key="debate_append_rerun")

        if approve:
            if not api_key or not api_key.strip():
                st.error("請先在左側輸入 OpenAI API Key。")
            else:
                last_session = dr["sessions"][-1]
                final_v3 = last_session[-1]["builder"]
                if _finalize_and_generate_verilog(final_v3):
                    st.session_state["debate_review"] = None
                    st.success("已批准：已完成規格濃縮與 Verilog 生成，見下方結果。")

        elif redo:
            if not api_key or not api_key.strip():
                st.error("請先在左側輸入 OpenAI API Key。")
            else:
                with st.spinner("重新辯論中（三輪 Builder ↔ Critic）…"):
