# =========================
# 後端邏輯：核心轉譯函式
# =========================
def _model_requires_api_key(model_name: str) -> bool:
    # LiteLLM: ollama/* 走本地，不需要 API key；其他供應商通常需要
    return not str(model_name or "").startswith("ollama/")


def generate_verilog(user_intent: str, api_key: str | None, model_name: str) -> str:
    """
    使用指定的 OpenAI API Key，根據使用者的自然語言需求，
    產生對應的 Cello Verilog 程式碼。

    回傳：
    - 成功：純 Verilog 程式碼字串。
    - 失敗：以「錯誤：」開頭的錯誤訊息字串（方便前端識別）。
    """
    if _model_requires_api_key(model_name) and (not api_key or not api_key.strip()):
        return "錯誤：尚未提供模型供應商 API Key。"

    if not user_intent or not user_intent.strip():
        return "錯誤：自然語言需求不可為空白。"

    # Cello 專用 System Prompt：確保大模型輸出標準結構化/資料流 Verilog
    system_prompt = """You are an expert biological circuit compiler for the Cello CAD software. Your ONLY job is to translate user requests into standard structural/dataflow Verilog code.

STRICT RULES:

Output ONLY raw, valid Verilog code.

NO Markdown formatting (Do NOT use ```verilog or ```).

NO conversational text, greetings, explanations, or comments outside the Verilog syntax.

Use simple logic gates (and, or, not, nor, nand) or assign statements.

EXAMPLE INPUT:
設計一個基因迴路，當有 IPTG 且沒有 aTc 時，輸出 YFP。

EXAMPLE OUTPUT:
module circuit(input IPTG, input aTc, output YFP);
wire not_aTc;
not(not_aTc, aTc);
and(YFP, IPTG, not_aTc);
endmodule"""

    try:
        response = litellm.completion(
            model=model_name,
            messages=[
                {"role": "system", "content": system_prompt},
                {
                    "role": "user",
                    "content": (
                        "請根據以下自然語言描述，設計對應的 Cello Verilog 基因電路：\n"
                        f"{user_intent}"
                    ),
                },
            ],
            temperature=0.2,  # 降低隨機性，讓輸出更穩定
            api_key=api_key.strip() if api_key and api_key.strip() else None,
        )

        verilog_code = response.choices[0].message["content"]

        # 安全檢查：若模型仍輸出 Markdown code fence，進行簡單清洗
        if "```" in verilog_code:
            verilog_code = (
                verilog_code.replace("```verilog", "")
                .replace("```", "")
                .strip()
            )

        return verilog_code

    except litellm.exceptions.AuthenticationError:
        return "錯誤：模型供應商 API 驗證失敗，請確認 API Key 是否正確與有效。"
    except litellm.exceptions.RateLimitError:
        return "錯誤：已達到模型供應商使用上限或額度不足，請稍後再試或檢查帳戶狀態。"
    except litellm.exceptions.BadRequestError as e:
        return f"錯誤：請求參數不正確：{str(e)}"
    except litellm.exceptions.APIError as e:
        return f"錯誤：呼叫模型供應商 API 時發生問題：{str(e)}"
    except Exception as e:
        # 非預期錯誤
        return f"錯誤：系統發生未預期錯誤：{str(e)}"


# =========================
# 多機辯論區塊（Reflexion）：三輪迭代 設計→評估→修改
# =========================
def _call_llm(api_key: str | None, model_name: str, system_prompt: str, user_content: str) -> str:
    """
    共用的 LLM 呼叫與錯誤處理，供 call_builder / call_critic / call_summarizer 使用。
    成功回傳助理回覆文字；失敗回傳以「錯誤：」開頭的字串。
    """
    try:
        response = litellm.completion(
            model=model_name,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": user_content},
            ],
            temperature=0.3,
            api_key=api_key.strip() if api_key and api_key.strip() else None,
        )
        return response.choices[0].message["content"].strip()
    except litellm.exceptions.AuthenticationError:
        return "錯誤：模型供應商 API 驗證失敗，請確認 API Key 是否正確與有效。"
    except litellm.exceptions.RateLimitError:
        return "錯誤：已達到模型供應商使用上限或額度不足，請稍後再試或檢查帳戶狀態。"
    except litellm.exceptions.BadRequestError as e:
        return f"錯誤：請求參數不正確：{str(e)}"
    except litellm.exceptions.APIError as e:
        return f"錯誤：呼叫模型供應商 API 時發生問題：{str(e)}"
    except Exception as e:
        return f"錯誤：系統發生未預期錯誤：{str(e)}"


def call_builder(
    user_intent: str,
    previous_feedback: str,
    api_key: str | None,
    model_name: str,
    *,
    rag_context: str = "",
    round1_debate_transcript: str | None = None,
) -> str:
    """
    專家一：合成生物學系統工程師（Reflexion 版）。
    若無 previous_feedback 則提出 V1；若有則在「絕對不違反用戶最終目標」前提下提出修正版。
    round1_debate_transcript：僅在第一輪且無 previous_feedback 時使用，將此前完整辯論紀錄一併納入語境。
    """
    system_prompt = (
        f"你是一位合成生物學系統工程師。用戶的最終目標是：{user_intent}。"
        "如果沒有 previous_feedback，請直接提出 V1 基因電路設計（包含輸入、邏輯閘、輸出）。"
        "如果收到 previous_feedback，請在**「絕對不能違反用戶最終目標」**的前提下，"
        "提出修正後的版本來解決批評者提出的問題。"
        f"【硬性約束】你只能使用以下 Cello 元件庫進行設計：\n{rag_context}\n絕對禁止使用清單外或捏造的元件。"
    )
    if previous_feedback:
        user_content = f"【批評者意見，請據此修正設計】\n{previous_feedback}"
    elif round1_debate_transcript:
        user_content = (
            "【此前完整辯論紀錄（請承接脈絡，不可忽略；並須完全符合下方「用戶最終目標」）】\n"
            f"{round1_debate_transcript}\n\n"
            "請綜合以上紀錄與用戶最終目標，提出本輪第一版（V1）基因電路設計。"
        )
    else:
        user_content = "請根據上述用戶最終目標，提出第一版（V1）基因電路設計。"
    return _call_llm(api_key, model_name, system_prompt, user_content)


def call_critic(
    current_design: str,
    api_key: str | None,
    model_name: str,
    *,
    rag_context: str = "",
    debate_transcript: str | None = None,
) -> str:
    """
    專家二：嚴苛的生物安全與可行性審查員。
    只專注於：邏輯矛盾、生物學現實問題（代謝負擔、毒性）、生物安全風險。提出精確、致命的批評。
    debate_transcript：若有，一併提供此前辯論紀錄供語境對齊（例如追加條件後的再辯論）。
    """
    system_prompt = (
        "你是一位嚴苛的生物安全與可行性審查員。請檢視當前的基因電路設計，只專注於尋找："
        "1. 邏輯矛盾 2. 生物學現實問題（代謝負擔、毒性） 3. 生物安全風險。"
        "提出精確、致命的批評，不說廢話。"
        f"【審查基準】請嚴格對照以下元件清單：\n{rag_context}\n若 Builder 捏造了清單外的元件，請給予嚴厲批評並要求修正。"
    )
    if debate_transcript:
        user_content = (
            "【此前完整辯論紀錄（供你對齊語境與使用者意圖）】\n"
            f"{debate_transcript}\n\n"
            "【當前待審查的設計】\n"
            f"{current_design}"
        )
    else:
        user_content = current_design
    return _call_llm(api_key, model_name, system_prompt, user_content)


def call_summarizer(final_design: str, api_key: str | None, model_name: str) -> str:
    """
    專家三：首席架構師。
    將第三輪的最終設計濃縮成 Verilog 轉譯器需要的純邏輯自然語言（例如：「當有 A 且沒有 B 時，輸出 C。」）。
    """
    system_prompt = (
        "你是一位首席架構師。請將以下基因電路設計（可能為多輪迭代後的完整描述）"
        "濃縮成一段極度精煉的自然語言，只描述邏輯關係，因為你的輸出將直接送給 Verilog 編譯器。"
        "例如：『當有 A 且沒有 B 時，輸出 C。』不要輸出其他解釋或標記。"
    )
    return _call_llm(api_key, model_name, system_prompt, final_design)


def format_sessions_for_display(sessions: list[list[dict]]) -> str:
    """將多段三輪辯論整理成給使用者閱讀的完整文字。"""
    parts: list[str] = []
    for si, session in enumerate(sessions, start=1):
        parts.append(f"════════ 辯論段落 {si} ════════")
        for round_num, turn in enumerate(session, start=1):
            parts.append(f"\n── 第 {round_num} 輪 ──")
            parts.append("\n【合成生物學系統工程師】\n")
            parts.append(turn.get("builder", ""))
            parts.append("\n\n【嚴苛的生物安全與可行性審查員】\n")
            parts.append(turn.get("critic", ""))
        parts.append("\n")
    return "\n".join(parts).strip()


def format_sessions_for_llm(sessions: list[list[dict]]) -> str:
    """與 display 相同結構即可，供後續輪次餵給 LLM。"""
    return format_sessions_for_display(sessions)


def _compact_rag_context(
    rag_results: list[str] | str,
    *,
    max_items: int = 8,
    max_chars: int = 2400,
) -> str:
    """
    將 RAG 檢索結果壓縮成較短的上下文，避免 Prompt 過長。

    策略：
    - 若是 list：優先保留看起來屬於 sensors / gates / output_devices 的描述
    - 去除重複與空白
    - 限制最多條目數與總字元數
    """
    if isinstance(rag_results, str):
        text = rag_results.strip()
        return text[:max_chars] if len(text) > max_chars else text

    raw_items = [x.strip() for x in rag_results if isinstance(x, str) and x.strip()]
    if not raw_items:
        return ""

    # 依描述字串常見關鍵字做輕量分類（不依賴固定 schema）
    keys = (
        "感測器",
        "sensor",
        "輸入",
        "input",
        "邏輯閘",
        "gate",
        "NOR",
        "NOT",
        "output device",
        "output_device",
        "output_devices",
        "輸出元件",
        "輸出",
    )
    filtered: list[str] = [x for x in raw_items if any(k.lower() in x.lower() for k in keys)]
    if not filtered:
        filtered = raw_items

    # 去重但保持順序
    seen: set[str] = set()
    uniq: list[str] = []
    for x in filtered:
        if x not in seen:
            seen.add(x)
            uniq.append(x)

    # 條目數限制
    uniq = uniq[:max_items]

    # 總長度限制（逐條累加，避免截斷到一半）
    out_lines: list[str] = []
    total = 0
    for item in uniq:
        line = f"- {item}"
        if out_lines:
            projected = total + 1 + len(line)
        else:
            projected = total + len(line)
        if projected > max_chars:
            break
        out_lines.append(line)
        total = projected

    return "\n".join(out_lines).strip()


def get_compressed_rag_context(query: str, api_key: str) -> str:
    """
    取得並壓縮 RAG 元件語境。
    成功：回傳壓縮後字串；失敗：回傳以「錯誤：」開頭的訊息。
    """
    if not api_key or not api_key.strip():
        return "錯誤：尚未提供 API Key。"
    if not query or not query.strip():
        return "錯誤：查詢內容不可為空白。"
    try:
        # Backward-compat shim (OpenAI embeddings only)
        rag_results = search_parts(query, embedding_model="text-embedding-3-small", api_key=api_key)
        if not rag_results:
            return "錯誤：RAG 檢索失敗：未取得任何元件結果。"
        rag_context = _compact_rag_context(rag_results)
        if not rag_context.strip():
            return "錯誤：RAG 檢索失敗：檢索結果為空白。"
        return rag_context
    except Exception as e:
        return f"錯誤：RAG 檢索失敗：{str(e)}"


def get_compressed_rag_context_v2(
    query: str,
    *,
    embedding_model: str,
    embedding_api_key: str | None = None,
    embedding_api_base: str | None = None,
) -> str:
    """
    取得並壓縮 RAG 元件語境（支援本地 embeddings，例如 Ollama）。
    成功：回傳壓縮後字串；失敗：回傳以「錯誤：」開頭的訊息。
    """
    if not query or not query.strip():
        return "錯誤：查詢內容不可為空白。"
    if not embedding_model or not str(embedding_model).strip():
        return "錯誤：尚未指定 Embedding Model。"
    try:
        rag_results = search_parts(
            query,
            embedding_model=embedding_model,
            api_key=embedding_api_key,
            api_base=embedding_api_base,
        )
        if not rag_results:
            return "錯誤：RAG 檢索失敗：未取得任何元件結果。"
        rag_context = _compact_rag_context(rag_results)
        if not rag_context.strip():
            return "錯誤：RAG 檢索失敗：檢索結果為空白。"
        return rag_context
    except Exception as e:
        return f"錯誤：RAG 檢索失敗：{str(e)}"


def run_three_round_reflexion(
    api_key: str | None,
    model_name: str,
    user_intent: str,
    *,
    carry_transcript: str | None = None,
    rag_context: str = "",
    on_round_complete=None,
) -> tuple[bool, list[dict], str | None, str | None]:
    """
    執行三輪 Builder↔Critic。
    carry_transcript：若提供（例如使用者追加條件後），第一輪 Builder 與每一輪 Critic 都會帶入完整此前紀錄。
    on_round_complete：可選，每輪結束時呼叫 callback(round_num, builder_text, critic_text)。
    回傳：(success, 本段三輪的 [{builder, critic}, ...], 第三輪 Builder 產出即最終設計, 錯誤訊息或 None)
    """
    previous_feedback = ""
    session_rounds: list[dict] = []
    final_design: str | None = None
    # 單次預先檢索：在開始三輪辯論前，把最相關的真實元件庫注入上下文
    #（此版本要求呼叫端先取得 rag_context，以便 UI 可展示透明度）
    if not rag_context.strip():
        return False, session_rounds, None, "錯誤：尚未提供 RAG Context。"
    if rag_context.startswith("錯誤："):
        return False, session_rounds, None, rag_context

    for round_num in range(1, 4):
        r1_ctx = carry_transcript if round_num == 1 else None
        current_design = call_builder(
            user_intent,
            previous_feedback,
            api_key,
            model_name,
            rag_context=rag_context,
            round1_debate_transcript=r1_ctx,
        )
        if current_design.startswith("錯誤："):
            return False, session_rounds, None, current_design

        critic_fb = call_critic(
            current_design,
            api_key,
            model_name,
            rag_context=rag_context,
            debate_transcript=carry_transcript,
        )
        if critic_fb.startswith("錯誤："):
            return False, session_rounds, None, critic_fb

        session_rounds.append({"builder": current_design, "critic": critic_fb})
        previous_feedback = critic_fb
        final_design = current_design
        if on_round_complete:
            on_round_complete(round_num, current_design, critic_fb)

    return True, session_rounds, final_design, None


