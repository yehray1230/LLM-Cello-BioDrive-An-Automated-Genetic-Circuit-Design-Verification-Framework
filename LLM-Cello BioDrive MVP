                    st.error(err_msg or "追加條件後的辯論失敗。")
                else:
                    dr["effective_intent"] = new_intent
                    dr["sessions"].append(new_sess)
                    st.session_state["debate_extra_widget_id"] = (
                        int(st.session_state["debate_extra_widget_id"]) + 1
